pipeline {
    agent any

    // NO parameters{} block — defined in UI Configure page

    environment {
        AWS_REGION   = 'ap-south-1'
        IMAGE_NAME   = 'myapp'
        ECR_UAT      = '111111111111.dkr.ecr.ap-south-1.amazonaws.com'
        ECR_PROD     = '222222222222.dkr.ecr.ap-south-1.amazonaws.com'
        ECR_REGISTRY = "${params.ENV == 'prod' ? ECR_PROD : ECR_UAT}"
        FULL_IMAGE   = "${ECR_REGISTRY}/${IMAGE_NAME}:${params.IMAGE_TAG}"
    }

    stages {

        stage('Checkout') {
            steps {
                git credentialsId: 'github-creds',
                    url: 'https://github.com/example/app.git',
                    branch: 'main'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Docker Build & Push') {
            steps {
                withCredentials([
                    aws(credentialsId: "aws-creds-${params.ENV}",
                        accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                        secretKeyVariable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    sh """
                        aws ecr get-login-password --region ${AWS_REGION} | \
                        docker login --username AWS \
                                     --password-stdin ${ECR_REGISTRY}

                        docker build -t ${FULL_IMAGE} .
                        docker push ${FULL_IMAGE}
                    """
                }
            }
        }

        stage('Prod Approval') {
            when {
                expression { params.ENV == 'prod' }
            }
            steps {
                input message: "Deploy ${FULL_IMAGE} to PROD?", ok: 'Approve'
            }
        }

        stage('Deploy to K8s') {
            steps {
                withCredentials([
                    aws(credentialsId: "aws-creds-${params.ENV}",
                        accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                        secretKeyVariable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    sh """
                        aws eks update-kubeconfig \
                          --region ${AWS_REGION} \
                          --name ${params.ENV}-cluster

                        sed -i 's|IMAGE_PLACEHOLDER|${FULL_IMAGE}|g' deployment.yaml
                        sed -i 's|ENV_PLACEHOLDER|${params.ENV}|g'   deployment.yaml

                        echo "=== Final deployment.yaml ==="
                        cat deployment.yaml
                        echo "=============================="

                        kubectl apply -f deployment.yaml \
                          --namespace ${params.ENV}

                        kubectl rollout status deployment/myapp \
                          --namespace ${params.ENV} \
                          --timeout=5m
                    """
                }
            }
        }

    }

    post {
        success {
            echo "✅ ${FULL_IMAGE} deployed to ${params.ENV}"
        }
        failure {
            withCredentials([
                aws(credentialsId: "aws-creds-${params.ENV}",
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY')
            ]) {
                sh """
                    aws eks update-kubeconfig \
                      --region ${AWS_REGION} \
                      --name ${params.ENV}-cluster

                    kubectl rollout undo deployment/myapp \
                      --namespace ${params.ENV} || true
                """
            }
            echo "❌ Deploy failed — rolled back ${params.ENV}"
        }
        always {
            sh "docker rmi ${FULL_IMAGE} || true"
        }
    }
}








