version: 0.2

phases:

  # ─────────────────────────────────────────
  # stage('Checkout') → handled by CodePipeline automatically
  # ─────────────────────────────────────────

  # ─────────────────────────────────────────
  # stage('Build')
  # ─────────────────────────────────────────
  install:
    runtime-versions:
      java: corretto17          //  ← Install Java 17 (Amazon Corretto) needed for Maven to build JAR   
    commands:
      - echo "Installing kubectl..."
      - curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"  //Follows redirects + saves file ✅
      - chmod +x kubectl && mv kubectl /usr/local/bin/

  pre_build:
    commands:
      - echo "Building JAR..."
      - mvn clean package

  # ─────────────────────────────────────────
  # stage('Docker Build')
  # ─────────────────────────────────────────
  build:
    commands:
      - echo "Building Docker image..."
      - docker build -t myapp:$CODEBUILD_BUILD_NUMBER .

  # ─────────────────────────────────────────
  # stage('Push Image') + stage('Deploy to K8s')
  # ─────────────────────────────────────────
  post_build:
    commands:
      - echo "Pushing Docker image..."
      - docker push myapp:$CODEBUILD_BUILD_NUMBER
      - echo "Deploying to K8s..."
      - kubectl apply -f deployment.yaml

artifacts:
  files:
    - target/myapp.jar
    - Deployment.yaml
